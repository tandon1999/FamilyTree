@if (isVisible)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);z-index:99999" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered @Options.DialogCssClass @GetModalSize()" role="document">
            <div class="modal-content">
                <div class="modal-header @Options.HeaderCssClass">
                    <h5 class="modal-title">@Title</h5>
                    @if (Options.Dismissable)
                    {
                        <button type="button" class="close" @onclick="Cancel" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    }
                </div>
                <div class="modal-body">
                    <p>@Message1</p>
                </div>
                <div class="modal-footer">
                    <button class="btn @GetNoButtonColor()" @onclick="Cancel">@Options.NoButtonText</button>
                    <button class="btn @GetYesButtonColor()" @onclick="Confirm">@Options.YesButtonText</button>
                </div>
            </div>
        </div>
    </div>
}
