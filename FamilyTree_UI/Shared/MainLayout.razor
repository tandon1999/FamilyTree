@using Blazored.Toast
@using Blazored.Toast.Services
@using FamilyTree_UI.Pages.FamilySetups
@using FamilyTree_UI.Shared.Component
@using Microsoft.Extensions.Localization
@using Microsoft.VisualBasic
@inject IJSRuntime JSRuntime
@inherits LayoutComponentBase
<PageTitle>Family Tree - Tandan</PageTitle>

<div class="page">
    <div class="sidebar">
        <NavMenu LoginExpiry="@_loginExpiryTime" />
    </div>
    <main>
        <div class="content px-4">
            <div class="top-bar">
                <select @onchange="ChangeLanguage" value="@selectedLanguage">
                    <option value="en">English</option>
                    <option value="ne">Nepali</option>
                </select>
            </div>
            <DialogBox/>
            @Body
            <Loader @ref="loader" />
            <BlazoredToasts />
        </div>
    </main>
</div>
