<link rel="stylesheet" href="/css/home.css">
@inject ConfirmDialogService dialog

<nav class="custom-navbar">
    <div class="nav-container w-100">
        <a class="nav-brand" href="/">
            <img src="/TandanLogo1.png" alt="Tandan Family Logo" class="nav-logo">
            <div class="brand-text">
                <span class="brand-title">Tandan Family Tree</span>
                <small class="brand-subtitle">Legacy • Stories • Generations</small>
            </div>
        </a>

        <button class="nav-toggle" @onclick="ToggleNavMenu" aria-label="Toggle navigation">
            <span class="hamburger-icon">&#9776;</span>
        </button>

        <div class="nav-menu @NavMenuCssClass">
            <ul class="nav-links mb-0">
                    <li><NavLink href="" Match="NavLinkMatch.All">Home</NavLink></li>
                    <li><NavLink href="familytree">Family Tree</NavLink></li>
                    <li><NavLink href="Timeline">TimeLine</NavLink></li>
                    <li><NavLink href="members-dictionary">Family Dictionary</NavLink></li>
                    <li><NavLink href="History">History</NavLink></li>
                    <li><NavLink href="Getgallery">Galleries</NavLink></li>
                    <li><NavLink href="Blog">Blogs</NavLink></li>
                    @if (RoleId == 1)
                    {
                        <li><NavLink href="admin">Dashboard</NavLink></li>
                    }
                    @if (!IsLoggedIn)
                    {
                        <li class="auth-item">
                            <NavLink href="login" class="auth-link login-link">
                                <span class="me-1">Login</span>
                                <span class="material-symbols-outlined">login</span>
                            </NavLink>
                        </li>
                    }
                    else
                    {
                        <li class="auth-item">
                            <button class="auth-link logout-link" @onclick="Logout" type="button">
                                <span class="me-1">Logout</span>
                                <span class="material-symbols-outlined">Logout</span>
                            </button>
                        </li>
                    }
                </ul>
        </div>
    </div>
</nav>

