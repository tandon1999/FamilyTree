@page "/blog"
<PageTitle>Blogs</PageTitle>

@using Microsoft.Extensions.Localization
<link href="css/blogpost.css" rel="stylesheet" />
<div class="blog-page container py-4 py-md-5">
    <section class="blog-hero mb-4 mb-md-5">
        <p class="blog-kicker mb-2">Family Writings</p>
        <h1 class="blog-hero-title mb-2">Stories Penned By Our Family Members</h1>
        <p class="blog-hero-subtitle mb-0">Read memories, reflections, and stories written across generations of the Tandan family.</p>
    </section>

    <div class="blog-grid">
        @if (blogsPostlist != null && blogsPostlist.Count > 0)
        {
            @foreach (var blog in blogsPostlist)
            {
                <div class="blog-card">
                    <div class="image-container">
                        <img src="@blog.ImageSrc" alt="@blog.Title" class="blog-image" @onload="(() => HandleImageLoadComplete())" @onerror="(() => HandleImageLoadComplete())" />
                    </div>

                    <div class="content">
                        <div class="metadata">
                            <span>@ConvertNE.ConvertEToNWithSlash(@blog.CreatedDate)</span> | <span>Tandan Family</span>
                        </div>
                        <h2 class="blog-title">@blog.Title</h2>
                        @if (blog.Content.Length > 200)
                        {
                            <p class="blog-excerpt">@blog.Content.Substring(0, 200)...</p>
                        }
                        else
                        {
                            <p class="blog-excerpt">@blog.Content</p>
                        }
                        <span class="read-more" @onclick="()=>GotoBlogDetails(blog.Id)" style="cursor:pointer">Read More</span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="no-posts text-center">
                <p>Loading Blogs . . .</p>

            </div>
        }
    </div>
</div>