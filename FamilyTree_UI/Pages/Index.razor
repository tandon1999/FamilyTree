    .card-title {
        font-size: 1.2rem;
    }

    .card-text {
        font-size: 0.9rem;
    }

    .search-input {
        height: 45px;
        border-radius: 40px;
    }
} */


.get-to-know-item {
    background-color: #f8f9fa; /* Light background for each item */
    padding: 20px;
    border-radius: 15px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1); /* Soft shadow */
    margin-bottom: 20px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.get-to-know-item:hover {
    transform: translateY(-10px); /* Slight lift effect */
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15); /* Enhanced shadow on hover */
}

.get-to-know-title {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 15px;
    color: #343a40; /* Darker text for better readability */
}

.btn-outline-primary {
    border-radius: 50px;
    padding: 10px 20px;
    font-size: 1rem;
    transition: background-color 0.3s ease, color 0.3s ease;
}

.btn-outline-primary:hover {
    background-color: #007bff; /* Change to primary color on hover */
    color: #ffffff;
    border-color: #007bff;
}

.row.mb-5 {
    display: flex;
    justify-content: space-around; /* Space items evenly */
    flex-wrap: wrap; /* Ensure it adjusts for smaller screens */
    gap: 20px; /* Add gap between columns */
}

