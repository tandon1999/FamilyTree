@page "/timeline"

<h1>Family Timeline</h1>

<div class="timeline">
    @foreach (var member in familyTreeMemberlist)
    {
        <div class="timeline-event">
            <div class="timeline-event-content" @onclick="()=>Redirecttouserprofile(member.Id)" style="cursor:pointer">
                <div class="event-image">
                    <img src="@member.ImageSrc" alt="@member.FullName" />
                </div>
                <strong>
                    @if (member.Type == 1)
                    {
                        <span style="color: #388e3c;">@member.FullName</span>
                    }
                    else if (member.Type == 2)
                    {
                        <span style="color: #d32f2f;">@member.FullName</span>
                    }
                    else
                    {
                        @member.FullName
                    }
                </strong>
                <div>
                    <strong><small>@ConvertNE.ConvertEToNWithSlash(member.Date)</small></strong>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .timeline {
        position: relative;
        max-width: 600px;
        margin: 50px auto;
    }

        .timeline::before {
            content: '';
            position: absolute;
            width: 4px;
            background-color: ghostwhite;
            top: 0;
            bottom: 0;
            left: 50%;
            margin-left: -2px;
        }

    .timeline-event {
        position: relative;
        background-color: inherit;
        width: 50%;
        margin-bottom: 20px;
    }

        .timeline-event::after {
            content: '';
            position: absolute;
            width: 25px;
            height: 25px;
            right: -17px;
            background-color: dimgrey;
            border: 4px solid #ddd;
            top: 15px;
            border-radius: 50%;
            z-index: 1;
        }

        .timeline-event:nth-child(odd) {
            left: 0;
            padding-right: 30px;
        }

        .timeline-event:nth-child(even) {
            left: 50%;
            padding-left: 30px;
        }

            .timeline-event:nth-child(even)::after {
                left: -17px;
            }

    .timeline-event-content {
        background-color: white;
        padding: 20px 30px;
        border-radius: 6px;
        box-shadow: 0 0 6px rgba(0, 0, 0, 0.15);
        position: relative;
    }

    .timeline-event-icon {
        position: absolute;
        top: 10px;
        width: 100px; /* Increased to fit the image */
        height: 100px; /* Increased to fit the image */
        border-radius: 50%;
        text-align: center;
        line-height: 40px;
        font-size: 20px;
        background-color: white; /* Changed to white to fit image*/
        color: white; /* changed to white to fit image*/
        overflow: hidden;
    }

    .timeline-event:nth-child(odd) .timeline-event-icon {
        right: -120px; /* adjusted to fit the image */
    }

    .timeline-event:nth-child(even) .timeline-event-icon {
        left: -120px; /* adjusted to fit the image */
    }

    .event-image {
        border-radius: 50%;
        width: 150px; /* Fixed width */
        height: 150px; /* Fixed height */
        overflow: hidden;
        flex-shrink: 0;
    }

        .event-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
</style>
