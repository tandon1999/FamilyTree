@page "/timeline"
<PageTitle>Family TimeLine</PageTitle>

<div class="timeline-page container py-4 py-md-5">
    <header class="timeline-header text-center mb-4 mb-md-5">
        <p class="timeline-kicker mb-2">Family Journey</p>
        <h1 class="timeline-title mb-2">Family Timeline</h1>
        <p class="timeline-subtitle mb-0">Follow major milestones and life events across generations.</p>
    </header>

    <div class="timeline">
        @if (familyTreeMemberlist != null && familyTreeMemberlist.Any())
        {
            @foreach (var member in familyTreeMemberlist)
            {
                <div class="timeline-event">
                    <article class="timeline-event-content" @onclick="()=>Redirecttouserprofile(member.Id)">
                        <div class="event-image">
                            <img src="@member.ImageSrc" alt="@member.FullName" />
                        </div>
                        <div class="event-details">
                            <h5 class="mb-1 @(member.Type == 1 ? "name-birth" : member.Type == 2 ? "name-death" : "")">@member.FullName</h5>
                            <small class="event-date">@ConvertNE.ConvertEToNWithSlash(member.Date)</small>
                        </div>
                    </article>
                </div>
            }
        }
        else
        {
            <div class="timeline-empty">Loading Family Timeline . . .</div>
        }
    </div>
</div>

<style>
    .timeline-page {
        max-width: 1100px;
    }

    .timeline-header {
        background: linear-gradient(135deg, #edf5ff 0%, #f8faff 100%);
        border: 1px solid #dce9fb;
        border-radius: 1rem;
        padding: 1.5rem 1rem;
    }

    .timeline-kicker {
        display: inline-block;
        padding: .25rem .65rem;
        border-radius: 999px;
        background: #dce8ff;
        color: #2f5cab;
        font-size: .82rem;
        font-weight: 600;
    }

    .timeline-title {
        font-size: clamp(1.5rem, 3vw, 2.3rem);
        color: #1e2d4c;
        font-weight: 700;
    }

    .timeline-subtitle {
        color: #516381;
    }

    .timeline {
        position: relative;
        max-width: 900px;
        margin: 0 auto;
        padding: .5rem 0;
    }

        .timeline::before {
            content: '';
            position: absolute;
            width: 3px;
            background: linear-gradient(#cad9f5, #9fb9ec);
            top: 0;
            bottom: 0;
            left: 50%;
            margin-left: -1.5px;
        }

    .timeline-event {
        position: relative;
        background-color: inherit;
        width: 50%;
        margin-bottom: 1rem;
    }

        .timeline-event::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            right: -8px;
            background-color: #4e73c7;
            border: 3px solid #fff;
            top: 24px;
            border-radius: 50%;
            z-index: 1;
            box-shadow: 0 0 0 3px #d9e5fb;
        }

        .timeline-event:nth-child(odd) {
            left: 0;
            padding-right: 1.2rem;
        }

        .timeline-event:nth-child(even) {
            left: 50%;
            padding-left: 1.2rem;
        }

            .timeline-event:nth-child(even)::after {
                left: -8px;
            }

    .timeline-event-content {
        background-color: #fff;
        padding: .85rem;
        border-radius: .85rem;
        box-shadow: 0 8px 20px rgba(27, 52, 101, 0.09);
        position: relative;
        border: 1px solid #e6ecf9;
        display: flex;
        gap: .75rem;
        align-items: center;
        cursor: pointer;
        transition: transform .2s ease, box-shadow .2s ease;
    }

    .timeline-event-content:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(27, 52, 101, 0.13);
    }

    .event-image {
        border-radius: 50%;
        width: 72px;
        height: 72px;
        overflow: hidden;
        flex-shrink: 0;
        border: 3px solid #edf2fd;
    }

        .event-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .event-date {
        color: #5f7293;
        font-weight: 600;
    }

    .name-birth {
        color: #2f8c4e;
    }

    .name-death {
        color: #cb3f44;
    }

    .timeline-empty {
        text-align: center;
        color: #5f7190;
        padding: 1.2rem;
        border: 1px dashed #ccd8ee;
        border-radius: .8rem;
        background: #f8fbff;
    }

    @@media (max-width: 768px) {
        .timeline::before {
            left: 14px;
        }

        .timeline-event,
        .timeline-event:nth-child(even) {
            width: 100%;
            left: 0;
            padding-left: 2rem;
            padding-right: 0;
        }

        .timeline-event::after,
        .timeline-event:nth-child(even)::after {
            left: 6px;
            right: auto;
        }
    }
</style>
