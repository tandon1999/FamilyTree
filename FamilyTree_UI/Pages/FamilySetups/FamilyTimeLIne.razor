@page "/Timeline"
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari&display=swap" rel="stylesheet">

<div class="timeline-container">
    <div class="header-section">
        <div class="header-title">
            समयको माध्यमबाट
        </div>
        <h1>महत्वपूर्ण घटनाहरू</h1>
    </div>

    <div class="timeline">
        @if (familyTreeMemberlist != null && familyTreeMemberlist.Count > 0)
        {
            foreach (var member in familyTreeMemberlist)
            {
                <div class="timeline-item">
                    <div class="date-section">
                        <span class="date">@ConvertNE.ConvertEToNWithSlash(@member.Date)</span>
                    </div>
                    <div class="event-content" @onclick="()=>Redirecttouserprofile(member.Id)" style="cursor:pointer">
                        <div class="event-image">
                            <img src="@member.ImageSrc" alt="@member.FullName" />
                        </div>
                        <div class="event-info">
                            <h4>
                                @if (member.Type == 1)
                                {
                                    <span style="color: #388e3c;">@member.FullName</span>
                                }                              
                                else if (member.Type == 2)
                                {
                                    <span style="color: #d32f2f;">@member.FullName</span>
                                }
                                else
                                {
                                    @member.FullName
                                }
                            </h4>
                        </div>
                    </div>
                    <div class="timeline-line"></div>
                </div>
            }
        }
        else
        {
            <p>No family members found</p>
        }
    </div>
    <footer class="text-center mt-8 text-sm text-gray-500">
        <p>&copy; 2025 <a href="https://www.sumantandan.com.np" class="text-blue-500 hover:underline" target="_blank">https://www.sumantandan.com.np</a>. All rights reserved.</p>
    </footer>
</div>

<style>
    .timeline-container {
        background: linear-gradient(135deg, #e0f2f7, #f0f8ff);
        padding: 60px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 100vh; /* Ensure full viewport height */
    }

    .header-section {
        text-align: center;
        margin-bottom: 60px;
    }

    .header-title {
        font-size: 2.5rem;
        color: #336699;
        font-weight: 300;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    h1 {
        font-size: 3rem;
        font-weight: 600;
        color: #2c3e50;
        margin-top: 10px;
    }

    .timeline {
        position: relative;
        padding: 0 0 80px;
        width: 80%;
        max-width: 1200px;
    }

        .timeline::before {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 50px;
            width: 4px;
            background: linear-gradient(to bottom, #aed581, #66bb6a);
        }

    .timeline-item {
        display: flex;
        position: relative;
        margin-bottom: 80px;
        width: 100%;
        justify-content: flex-start;
        padding-left: 150px;
    }

        .timeline-item:nth-child(even) {
            justify-content: flex-end;
            padding-left: 0;
            padding-right: 150px;
        }

        .timeline-item .date-section {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.1rem;
            font-weight: 600;
            background-color: #fff;
            padding: 12px 25px;
            border-radius: 30px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
            white-space: nowrap;
            color: #333;
        }

        .timeline-item:nth-child(even) .date-section {
            right: -120px;
        }

        .timeline-item:nth-child(odd) .date-section {
            left: -120px;
        }

    .event-content {
        display: flex;
        align-items: center;
        background-color: #fff;
        padding: 20px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        width: 70%;
        max-width: 500px;
    }

    .timeline-item:nth-child(even) .event-content {
        flex-direction: row-reverse;
    }

    .event-image {
        border-radius: 50%;
        width: 100px;
        height: 100px;
        overflow: hidden;
        margin: 0 25px;
        flex-shrink: 0;
    }

        .event-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .event-info h4 {
        font-size: 1.6rem;
        font-weight: 600;
        color: #333;
        margin: 0;
    }

    .timeline-line {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 100px;
        height: 2px;
        background: linear-gradient(to right, #aed581, #66bb6a);
    }

    .timeline-item:nth-child(even) .timeline-line {
        left: auto;
        right: 100px;
        background: linear-gradient(to left, #aed581, #66bb6a);
    }

    .timeline-item:nth-child(odd) .timeline-line {
        left: 100px;
    }

    body {
        font-family: 'Noto Sans Devanagari', sans-serif;
    }
</style>