        background: linear-gradient(135deg, #eef4ff 0%, #f7f9ff 100%);
        border: 1px solid #dce7fb;
        border-radius: 1rem;
        padding: 1.5rem 1rem;
    }

    .history-kicker {
        display: inline-block;
        padding: .25rem .7rem;
        border-radius: 999px;
        background-color: #dce8ff;
        color: #305ca8;
        font-weight: 600;
        font-size: .82rem;
    }

    .history-title {
        font-size: clamp(1.5rem, 3vw, 2.4rem);
        color: #1f2c4a;
        font-weight: 700;
    }

    .history-subtitle {
        color: #506280;
    }

    .history-content {
        display: grid;
        gap: 1rem;
    }

    .history-section {
        background: #fff;
        border: 1px solid #e7edf9;
        border-radius: .9rem;
        padding: 1.2rem;
        box-shadow: 0 8px 20px rgba(29, 51, 93, 0.05);
    }

    .history-section h2 {
        font-size: 1.2rem;
        font-weight: 700;
        color: #273553;
        margin-bottom: .85rem;
        padding-bottom: .5rem;
        border-bottom: 1px solid #e6ecfa;
    }

    .history-section p {
        line-height: 1.85;
        color: #32476f;
        margin-bottom: .9rem;
    }
</style>