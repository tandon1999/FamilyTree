@page "/UserProfile/{Id}"
<PageTitle>User Profile</PageTitle>

<div class="profile-page container py-4 py-md-5">
    @if (memberSetupModel != null)
    {
        <section class="profile-card">
            <div class="profile-top">
                <img class="profile-image" src="@uploadedImageUrl" alt="Profile Picture" onerror="this.onerror=null;this.src='placeholder-image.jpg';" />
                <div>
                    <h1 class="profile-name">@($"{memberSetupModel.FirstName} {memberSetupModel.MiddleName} {memberSetupModel.LastName}")</h1>
                    <p class="profile-meta mb-0">@memberSetupModel.GenerationType | @memberSetupModel.OccupationType</p>
                </div>
            </div>

            <div class="profile-info mt-4">
                <div class="info-item">
                    <strong>Date of Birth</strong>
                    <span>@ConvertNE.ConvertEToNWithSlash(memberSetupModel.DOB)</span>
                </div>
                <div class="info-item">
                    <strong>Age</strong>
                    <span>@memberSetupModel.Age</span>
                </div>
                <div class="info-item">
                    <strong>Gender</strong>
                    <span>@memberSetupModel.GenderName</span>
                </div>
                <div class="info-item">
                    <strong>Occupation</strong>
                    <span>@memberSetupModel.OccupationType</span>
                </div>
                <div class="info-item">
                    <strong>Generation Type</strong>
                    <span>@memberSetupModel.GenerationType</span>
                </div>
                <div class="info-item">
                    <strong>Phone Number</strong>
                    <span>@(string.IsNullOrWhiteSpace(memberSetupModel.PhoneNumber) ? "N/A" : memberSetupModel.PhoneNumber)</span>
                </div>
                <div class="info-item">
                    <strong>Father's Name</strong>
                    <span class="relation-link" @onclick="()=>Redirecttouserprofile(memberSetupModel.FatherId)">@(string.IsNullOrWhiteSpace(memberSetupModel.FatherName) ? "N/A" : memberSetupModel.FatherName)</span>
                </div>
                <div class="info-item">
                    <strong>Mother's Name</strong>
                    <span class="relation-link" @onclick="()=>Redirecttouserprofile(memberSetupModel.MotherId)">@(string.IsNullOrWhiteSpace(memberSetupModel.MotherName) ? "N/A" : memberSetupModel.MotherName)</span>
                </div>
                @if (memberSetupModel.GenderId == 1)
                {
                    <div class="info-item">
                        <strong>Wife Name</strong>
                        <span class="relation-link" @onclick="()=>Redirecttouserprofile(memberSetupModel.WifeId)">@(string.IsNullOrWhiteSpace(memberSetupModel.WifeName) ? "N/A" : memberSetupModel.WifeName)</span>
                    </div>
                }
                else
                {
                    <div class="info-item">
                        <strong>Husband Name</strong>
                        <span class="relation-link" @onclick="()=>Redirecttouserprofile(memberSetupModel.HusbandId)">@(string.IsNullOrWhiteSpace(memberSetupModel.HusbandName) ? "N/A" : memberSetupModel.HusbandName)</span>
                    </div>
                }
                <div class="info-item">
                    <strong>Son's Names</strong>
                    @if (string.IsNullOrWhiteSpace(memberSetupModel.SonNames))
                    {
                        <span>N/A</span>
                    }
                    else
                    {

                        string[] sonNames = memberSetupModel.SonNames.Split(',');
                        string[] sonIds = memberSetupModel.SonIds.Split(',');

                        if (sonNames.Length == sonIds.Length)
                        {
                            for (int i = 0; i < sonNames.Length; i++)
                            {
                                int sonId = int.Parse(sonIds[i].Trim()); // Parse the ID as an integer
                                string sonName = sonNames[i].Trim();

                                <span class="relation-link" @onclick="() => Redirecttouserprofile(sonId)">
                                    @sonName@(i < sonNames.Length - 1 ? ", " : "")
                                </span>
                            }
                        }
                        else
                        {
                            <span>Error: Son names and IDs mismatch.</span>
                        }

                    }
                </div>

                <div class="info-item">
                    <strong>Daughter's Names</strong>
                    @if (string.IsNullOrWhiteSpace(memberSetupModel.DaughterNames))
                    {
                        <span>N/A</span>
                    }
                    else
                    {

                        string[] daughterNames = memberSetupModel.DaughterNames.Split(',');
                        string[] daughterIds = memberSetupModel.DaughterIds.Split(',');

                        if (daughterNames.Length == daughterIds.Length)
                        {
                            for (int i = 0; i < daughterNames.Length; i++)
                            {
                                int daughterId = int.Parse(daughterIds[i].Trim()); // Parse the ID as an integer
                                string daughterName = daughterNames[i].Trim();

                                <span class="relation-link" @onclick="() => Redirecttouserprofile(daughterId)">
                                    @daughterName@(i < daughterNames.Length - 1 ? ", " : "")
                                </span>
                            }
                        }
                        else
                        {
                            <span>Error: Daughter names and IDs mismatch.</span>
                        }

                    }
                </div>
                <div class="info-item">
                    <strong>Marital Status</strong>
                    <span>@memberSetupModel.MatrialStatus</span>
                </div>
                <div class="info-item">
                    <strong>Number of Children</strong>
                    <span>@memberSetupModel.NumberOfChildren</span>
                </div>
                <div class="info-item">
                    <strong>Address</strong>
                    <span>@(string.IsNullOrWhiteSpace(memberSetupModel.Address) ? "N/A" : memberSetupModel.Address)</span>
                </div>
                <div class="info-item">
                    <strong>Description</strong>
                    <span>@(string.IsNullOrWhiteSpace(memberSetupModel.Description) ? "N/A" : memberSetupModel.Description)</span>
                </div>
                <div class="info-item profile-status">
                    <strong>Status</strong>
                    <span class="@(memberSetupModel.HasValue == 1 ? "status-deceased" : "status-alive")">
                        @(memberSetupModel.HasValue == 1 ? "Death" : "Alive")
                    </span>
                </div>
                @if (memberSetupModel.HasValue == 1)
                {
                    <div class="info-item">
                        <strong>Death Date</strong>
                        <span>@ConvertNE.ConvertEToNWithSlash(memberSetupModel.DeathDate)</span>
                    </div>
                }
            </div>
        </section>
    }
    else
    {
        <div class="profile-loading">Loading profile...</div>
    }
</div>

<style>
    .profile-page {
        max-width: 1100px;
    }

    .profile-card {
        background: #fff;
        border: 1px solid #e5ebf8;
        border-radius: 1rem;
        box-shadow: 0 12px 28px rgba(30, 54, 102, 0.08);
        padding: 1.25rem;
    }

    .profile-top {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        border-radius: .9rem;
        background: linear-gradient(135deg, #edf4ff 0%, #f8fbff 100%);
        border: 1px solid #dce8fb;
    }

    .profile-image {
        width: 125px;
        height: 125px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #fff;
        box-shadow: 0 8px 16px rgba(29, 56, 105, 0.18);
    }

    .profile-name {
        font-size: clamp(1.3rem, 2.5vw, 2rem);
        font-weight: bold;
        margin-bottom: .3rem;
        color: #1f2d4b;
    }

    .profile-meta {
        color: #586b8c;
    }

    .profile-info {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: .75rem;
    }

    .info-item {
        background-color: #f9fbff;
        border: 1px solid #e6edf9;
        border-radius: .75rem;
        padding: .75rem .8rem;
        text-align: left;
    }

        .info-item strong {
            display: block;
            color: #63779b;
            margin-bottom: .25rem;
            font-size: .85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .03em;
        }

        .info-item span {
            font-weight: 600;
            color: #263755;
            line-height: 1.5;
        }

    .relation-link {
        cursor: pointer;
        color: #2d5eb0 !important;
        text-decoration: none;
    }

    .relation-link:hover {
        text-decoration: underline;
        }

    .profile-status .status-alive {
        color: #2b9551;
        font-weight: bold;
    }

    .profile-status .status-deceased {
        color: #cc4646;
        font-weight: bold;
    }

    .profile-loading {
        border: 1px dashed #cad8ee;
        border-radius: .8rem;
        padding: 1rem;
        color: #5e7191;
        background: #f8fbff;
        text-align: center;
    }

    @@media (max-width: 768px) {
        .profile-top {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
