<div class="family-tree">
    @if (familyTreeMemberlist != null && familyTreeMemberlist.Any())
    {
        @foreach (var generationId in familyTreeMemberlist.Select(m => m.GenerationId).Distinct().OrderBy(g => g))
        {
            <!-- Set dynamic margin based on generation -->
            <div class="generation" style="@($"margin-left: {generationId * 100}px; {GetGenerationColor(generationId)}")">
                <h3>@GetGenerationType(generationId)</h3>
                <div class="members">
                    @foreach (var member in familyTreeMemberlist.Where(m => m.GenerationId == generationId).OrderBy(m => m.GenderId))
                    {
                        <!-- Determine alignment and color based on IdentificationId -->
                        <div class="member @GetMemberAlignment(member.IdentificationID)"
                             style="background-color:@GetMemberColor(member.IdentificationID)">
                            @if (!string.IsNullOrEmpty(member.ImageSrc))
                            {
                                <img src="@member.ImageSrc" alt="@member.FullName" class="member-image" />
                            }
                            else
                            {
                                <div class="member-placeholder">No Image</div>
                            }
                            <div class="member-details">
                                <p><strong>@member.FullName</strong></p>
                                <p><strong>@member.Identification</strong></p>
                                <p>जन्म मिति: @ConvertNE.ConvertEToNWithSlash(@member.DOB)</p>
                                @if (member.DeathDate != DateTime.MinValue)
                                {
                                    <p>मृत्यु मिति: @ConvertNE.ConvertEToNWithSlash(@member.DeathDate)</p>
                                }
                                @if (member.HasWife == 1)
                                {
                                    <span class="material-symbols-outlined"
                                          @onclick="() => OnBranchIconClick(member.Id)"
                                          style="cursor:pointer;color:#EA3323"
                                          title="branch">
                                        graph_2
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p>No family members found.</p>
    }
</div>
<style>
    .family-tree {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .generation {
        margin-bottom: 20px;
        text-align: center;
        padding: 10px;
        border-radius: 5px;
    }

    .members {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
    }

    .member {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin: 10px;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 5px;
        text-align: center;
        width: 200px;
    }

    /* Son (Id = 3) alignment */
    .member-left {
        float: left;
        background-color: #ADD8E6; /* Light blue for sons */
    }

    /* Daughter (Id = 4) alignment */
    .member-right {
        float: right;
        background-color: #FFB6C1; /* Light pink for daughters */
    }

    .member-image {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 50%;
        margin-bottom: 10px;
    }

    .member-placeholder {
        width: 100px;
        height: 100px;
        background-color: #f0f0f0;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 50%;
        margin-bottom: 10px;
    }

    .member-details {
        text-align: left;
    }

    .branch-button {
        margin-top: 10px;
    }

</style>

