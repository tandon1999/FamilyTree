@page "/familytree"
<PageTitle>Family Tree</PageTitle>
@using FamilyTree_UI.ViewModels
<link href="css/Familyui.css" rel="stylesheet" />
<h1 class="text-center">Tandan - Genealogy</h1>
<div class="family-tree-container">
    @if (familyTreeMemberlist != null && familyTreeMemberlist.Any())
    {  
            var generations = familyTreeMemberlist.GroupBy(m => m.GenerationId).OrderBy(g => g.Key).ToList();
        @foreach (var generation in generations)
        {
            <div class="generation-row" style="@GetGenerationColor(generation.Key); margin-left: @(generation.Key * 100)px;">
                <div class="generation-label">@GetGenerationType(generation.Key)</div>
                <div class="members">
                    @foreach (var member in generation)
                    {
                        @* <div class="member-container @GetMemberAlignment(member.GenerationId)" style="background-color: @GetMemberColor(member.GenerationId);">
                            <div class="member-image">
                                @if (!string.IsNullOrEmpty(member.ImageSrc))
                                {
                                    <img src="@member.ImageSrc" alt="@member.FullName" style="width: 100px; height: 100px; border-radius: 50%;" />
                                }
                                else
                                {
                                    <div style="width: 100px; height: 100px; border-radius: 50%; background-color: lightgray; display: flex; align-items: center; justify-content: center;">
                                        <span>No Image</span>
                                    </div>
                                }
                            </div>
                            <div class="member-identification">@member.Identification</div>
                            <div class="member-details">
                                <div>@member.FullName</div>
                                @if (member.HasWife == 1)
                                {
                                    <span class="material-symbols-outlined branch-icon"
                                          @onclick="() => OnBranchIconClick(member.Id)"
                                          title="branch">
                                        graph_2
                                    </span>
                                }
                            </div>

                        </div> *@
                        <div class="member-container" style="background-color: @GetMemberColor(member.GenerationId);">
                            <div class="member-identification">@member.Identification</div>

                            <div class="member-image">
                                @if (!string.IsNullOrEmpty(member.ImageSrc))
                                {
                                    <img src="@member.ImageSrc" alt="@member.FullName" style="width: 100px; height: 100px; border-radius: 50%;" />
                                }
                                else
                                {
                                    <div style="width: 100px; height: 100px; border-radius: 50%; background-color: lightgray; display: flex; align-items: center; justify-content: center;">
                                        <span>No Image</span>
                                    </div>
                                }
                            </div>

                            <div class="member-details">
                                <div>@member.FullName</div>
                            </div>

                            @if (member.HasWife == 1)
                            {
                                <span class="material-symbols-outlined branch-icon"
                                      @onclick="() => OnBranchIconClick(member.Id)"
                                      title="branch">
                                    graph_2
                                </span>
                            }
                        </div>

                    }
                </div>
                @if (generations.IndexOf(generation) < generations.Count - 1)
                {
                    <div class="connector"></div>
                }
            </div>
        }
    }
    else
    {
        <p>Loading Family Tree . . .</p>
    }
</div>



