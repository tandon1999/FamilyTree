<div class="tree">
    @if (familyTreeMemberlist != null && familyTreeMemberlist.Count > 0)
    {
        <div class="family-tree">
            @foreach (var member in familyTreeMemberlist)
            {
                <div class="family-member-card">
                    @if (!string.IsNullOrEmpty(member.ImageSrc))
                    {
                        <img src="@member.ImageSrc" alt="@member.FullName" class="family-member-image" />
                    }
                    else
                    {
                        <img src="placeholder-image.png" alt="No Image" class="family-member-image" />
                    }

                    <div class="family-member-details">
                        <h4> <strong>@member.FullName</strong></h4>
                        <p>
                            <strong>जन्म मिति:</strong> @ConvertNE.ConvertEToNWithSlash(@member.DOB)
                        </p>
                        @if (member.DeathDate != default(DateTime))
                        {
                            <p>
                                <strong>मृत्यु मिति:</strong> @member.DeathDate.ToShortDateString()
                            </p>
                        }
                    </div>

                    @if (member.HasWife == 1)
                    {
                        @if (!member.IsIconDisabled)
                        {
                            <span class="material-symbols-outlined"
                                  @onclick="() => OnBranchIconClick(member.Id)"
                                  style="cursor:pointer;color:#EA3323"
                                  title="branch">
                                graph_2
                            </span>
                        }
                    }

                </div>
            }
        </div>
    }
</div>





<style>
    .family-tree {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
    }

    .family-member-card {
        border: 1px solid #ccc;
        padding: 15px;
        border-radius: 10px;
        width: 250px;
        text-align: center;
        box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
        position: relative;
        display: flex; /* Make the card a flex container */
        flex-direction: column; /* Stack content vertically */
        justify-content: space-between; /* Space items, ensuring the icon is at the bottom */
    }

    .family-member-image {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 15px;
    }

    .family-member-details {
        text-align: left;
        flex-grow: 1; /* Ensure the details take up the vertical space */
    }

        .family-member-details h4 {
            margin: 0;
            margin-bottom: 10px;
        }

    .leaf-icon {
        position: absolute;
        bottom: 10px;
        right: 10px;
        font-size: 20px;
        color: green;
    }

    .spouse {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 20px;
    }

</style>

