@page "/familylist"
@using FamilyTree_UI.Shared.Component
@using FamilyTree_UI.Shared.Services
@inject ConfirmDialogService dialog


@* <div>
    <button @onclick="AddNewFamilyMember" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create New Member
    </button>
</div> *@
<div style="display:flex; width:100%; justify-content:space-between; align-items:center;">
    <button @onclick="AddNewFamilyMember" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create New Member
    </button>
    <div style="position: relative;">
        <input type="search" style="border: 1px solid #123F6B; padding: 0 10px 0 30px; border-radius: 8px; font-size: 12px; height: 30px; width: 200px; box-sizing: border-box;"
               autofocus @bind="nameFilter" @bind:event="oninput" placeholder="Search By Name...">
                <span class="material-symbols-outlined search-icon" style="position: absolute; top: 50%; left: 8px; transform: translateY(-50%); color: #123F6B;">
                    search
                </span>
    </div>
</div>

<div class="table-responsive mt-4">
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>SN</th>
                <th>Full Name</th>
                <th>Date of Birth</th>
                <th>Age</th>
                <th>Gender</th>
                <th>Occupation</th>
                <th>Marital Status</th>
                <th>Father's Name</th>
                <th>Mother's Name</th>
                <th>Address</th>
                <th>Profile</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (familyTreeMemberlist != null && familyTreeMemberlist.Any())
            {
                var sn = 1;
                foreach (var member in familyTreeMemberlist)
                {
                    <tr>
                        <td>@sn</td>
                        <td>@member.FullName</td>
                        <td>@ConvertNE.ConvertEToNWithSlash(@member.DOB)</td>
                        <td>@member.Age</td>
                        <td>@member.GenderName</td>
                        <td>@member.OccupationType</td>
                        <td>@member.MatrialStatus</td>
                        <td>@member.FatherName</td>
                        <td>@member.MotherName</td>
                        <td class="truncated-address" title="@member.Address">
                            @if (member.Address.Length > 61)
                            {
                                @member.Address.Substring(1, 60)
                            }
                            else
                            {
                                @member.Address
                            }
                        </td>
                        <td>
                            <button @onclick="@((Id )=>ViewImage(member.Id))" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-eye"></i> View
                            </button>
                        </td>
                        <td>
                            <button @onclick="@((Id )=>Edit(member.Id))" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil-square"></i> Edit
                            </button>
                            <button @onclick="@((Id )=>Delete(member.Id))" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                    sn++;
                }
            }
            else
            {
                <tr>
                    <td colspan="12" class="text-center">No family members available.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<footer class="text-center mt-8 text-sm text-gray-500">
    <p>&copy; 2025 <a href="https://www.sumantandan.com.np" class="text-blue-500 hover:underline" target="_blank">https://www.sumantandan.com.np</a>. All rights reserved.</p>
</footer>


<Modal Title="Member Profile Picture" Show="@ShowModal" OnClose="@CloseModal" ShowSaveButton="false" Size="xl">
    <div class="Image">
        <iframe src="@Imagesrc" style="object-fit:contain; width:50vw;height:50vh;  box-shadow: 5px 5px 10px rgba(0, 0, 0, 0.2);"></iframe>
    </div>
</Modal>


@* <button class="btn btn-primary" @onclick="OpenModal">Open Modal</button>

<Modal Title="Family Member Details" Show="@ShowModal" OnClose="@CloseModal">
    <div class="Image">
        <iframe src="@Imagesrc" style="object-fit:contain; width:50vw;height:50vh;  box-shadow: 5px 5px 10px rgba(0, 0, 0, 0.2);"></iframe>
    </div>
</Modal> *@

<Modal Title="Edit Family Details" Show="@ShowModal1" OnClose="@CloseModal" OnSave="Save" Size="xl" ButtonType="Update">
    <!-- Image Upload Section -->

    <div class="family-setup-container">
        <div class="row">
            <div class="col-md-4">
                <div class="image-upload-section">
                    <div class="image-upload-box">
                        @if (string.IsNullOrEmpty(uploadedImageUrl))
                        {
                            <p>No image selected</p>
                        }
                        else
                        {
                            <img src="@uploadedImageUrl" alt="Profile Picture" class="preview-image" />
                        }
                    </div>
                    <div class="upload-btn-container">
                        <label for="ProfilePicture" class="upload-btn">
                            <i class="bi bi-upload"></i> Upload Image
                        </label>
                        <InputFile class="d-none" id="ProfilePicture" OnChange="HandleFileSelected" />
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group custom-input">
                            <label for="FirstName">First Name</label>
                            <InputText class="form-control" id="FirstName" @bind-Value="@memberSetupModel.FirstName" placeholder="Enter Your First Name" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group custom-input">
                            <label for="MiddleName">Middle Name</label>
                            <InputText class="form-control" id="MiddleName" @bind-Value="@memberSetupModel.MiddleName" placeholder="Enter Your Middle Name" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group custom-input">
                            <label for="LastName">Last Name</label>
                            <InputText class="form-control" id="LastName" @bind-Value="@memberSetupModel.LastName" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group custom-input">
                            <label for="Gender" class="label-title">Gender</label>
                            <AutoCompleteSelect Type="tblgender" Value="@memberSetupModel.Gender.ToString()" ValueChanged="@((Id)=>memberSetupModel.Gender= int.Parse(Id))"></AutoCompleteSelect>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group custom-input">
                            <label for="MaritalStatus" class="label-title">Marital Status</label>
                            <AutoCompleteSelect Type="tblMatrialStatus" Value="@memberSetupModel.MatrialStatus.ToString()" ValueChanged="@((Id)=>memberSetupModel.MatrialStatus= int.Parse(Id))"></AutoCompleteSelect>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group custom-input">
                            <label for="Occupation" class="label-title">Occupation</label>
                            <AutoCompleteSelect Type="tblOccupation" Value="@memberSetupModel.Occupation.ToString()" ValueChanged="@((Id)=>memberSetupModel.Occupation= int.Parse(Id))"></AutoCompleteSelect>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group custom-input">
                            <label for="FatherName" class="label-title">Father Name</label>
                            <AutoCompleteSelect Type="tblfather" Value="@memberSetupModel.FatherName.ToString()" ValueChanged="@((Id)=>memberSetupModel.FatherName= int.Parse(Id))"></AutoCompleteSelect>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group custom-input">
                            <label for="MotherName" class="label-title">Mother Name</label>
                            <AutoCompleteSelect Type="tblMother" Value="@memberSetupModel.MotherName.ToString()" ValueChanged="@((Id)=>memberSetupModel.MotherName= int.Parse(Id))"></AutoCompleteSelect>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="HusbandId">Husband Name</label>
                            <AutoCompleteSelect Type="tblhusband" Value="@memberSetupModel.HusbandId.ToString()" ValueChanged="@((Id)=>memberSetupModel.HusbandId= int.Parse(Id))"></AutoCompleteSelect>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="WifeId">Wife Name</label>
                            <AutoCompleteSelect Type="tblwife" Value="@memberSetupModel.WIfeId.ToString()" ValueChanged="@((Id)=>memberSetupModel.WIfeId= int.Parse(Id))"></AutoCompleteSelect>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="DOB">Date of Birth</label>
                            <InputDate class="form-control" id="DOB" @bind-Value="@memberSetupModel.DOB" @oninput="((ChangeEventArgs e) => CalculateAge(e, 1))" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="Age">Age</label>
                            <InputNumber class="form-control" id="Age" @bind-Value="@memberSetupModel.Age" ReadOnly />
                        </div>
                    </div>

                    <div class="col-md-2 mt-3">
                        <div class="form-group">
                            <label for="IsDeath">Is Death?</label>
                            <InputCheckbox id="IsDeath" @bind-Value="@memberSetupModel.IsDeath" @onclick="ClearDate" />
                        </div>
                    </div>

                    @if (memberSetupModel.IsDeath)
                    {
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="DeathDate">Death Date</label>
                                <InputDate class="form-control" id="DeathDate" @bind-Value="@memberSetupModel.DeathDate" @oninput="((ChangeEventArgs e) => CalculateAge(e, 2))" />
                            </div>
                        </div>
                    }

                    <div class="col-md-4">
                        <div class="form-group custom-input">
                            <label for="NumberOfChildren">No Of Children</label>
                            <InputNumber class="form-control" id="NumberOfChildren" @bind-Value="@memberSetupModel.NumberOfChildren" />
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="form-group custom-input">
                            <label for="Address">Address</label>
                            <InputTextArea class="form-control" id="Address" @bind-Value="@memberSetupModel.Address" placeholder="Please Enter Your Address....." />
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="form-group custom-input">
                            <label for="Description">Description</label>
                            <InputTextArea class="form-control" id="Description" @bind-Value="@memberSetupModel.Description" placeholder="Add a More Inforamtion Here....." />
                        </div>
                    </div>


                </div>
            </div>
        </div>
    </div>
</Modal>

<style>
    .table-responsive {
        overflow-x: auto;
    }

    .table {
        width: 100%;
        max-width: 100%;
        margin-bottom: 1rem;
        background-color: transparent;
        border-collapse: collapse;
    }

    .table-striped tbody tr:nth-of-type(odd) {
        background-color: rgba(0, 0, 0, 0.05);
    }

    .table-bordered {
        border: 1px solid #dee2e6;
    }

        .table-bordered th,
        .table-bordered td {
            border: 1px solid #dee2e6;
        }

    .table th,
    .table td {
        padding: 0.75rem;
        vertical-align: top;
        border-top: 1px solid #dee2e6;
    }

    .table thead th {
        vertical-align: bottom;
        border-bottom: 2px solid #dee2e6;
    }

    .table-striped tbody tr:nth-of-type(odd) {
        background-color: rgba(0,0,0,.05);
    }

    .family-setup-container {
        padding: 40px;
        background-color: #f8f9fa;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

        .family-setup-container h3 {
            text-align: center;
            margin-bottom: 30px;
            color: #333;
            font-size: 28px;
            font-weight: 600;
        }

    .image-upload-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 30px;
    }

    .image-upload-box {
        border: 2px dashed #ccc;
        padding: 20px;
        border-radius: 10px;
        width: 250px;
        height: 250px;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        background-color: #e9ecef;
        margin-bottom: 20px;
    }

    .upload-btn {
        display: inline-block;
        background-color: #007bff;
        color: white;
        padding: 12px 20px;
        border-radius: 5px;
        cursor: pointer;
        font-size: 16px;
        transition: background-color 0.3s;
    }

        .upload-btn:hover {
            background-color: #0056b3;
        }

    .preview-image {
        max-width: 100%;
        max-height: 100%;
        object-fit: cover;
        border-radius: 5px;
    }

    .upload-btn-container {
        text-align: center;
    }

    .image-modal {
        display: flex;
        justify-content: center;
        align-items: center;
    }
</style>