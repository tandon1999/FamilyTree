@using FamilyTree_UI.Pages.Blogs
@using FamilyTree_UI.Pages.FamilySetups
@using FamilyTree_UI.Pages.Galleries
@using FamilyTree_UI.Shared.Services

@page "/admin"
@page "/admin/{tabId:int}"

<div class="d-flex">
    @*     <div class="nav-dash">
    <nav class="admin-nav-bar-vertical d-flex flex-column">
    <span class="nav-link-item @(selectedTab == "dashboardhome" ? "active-nav" : "")" @onclick='() => NavigateToTab("dashboardhome")'>Dashboard Home</span>
    <span class="nav-link-item @(selectedTab == "Family-setup" ? "active-nav" : "")" @onclick='() => NavigateToTab("Family-setup")'>Family Setup</span>
    <span class="nav-link-item @(selectedTab == "Family-list" ? "active-nav" : "")" @onclick='() => NavigateToTab("Family-list")'>Family List</span>
    <span class="nav-link-item @(selectedTab == "gallery-setup" ? "active-nav" : "")" @onclick='() => NavigateToTab("gallery-setup")'>Galleries Setup</span>
    <span class="nav-link-item @(selectedTab == "blogs-setup" ? "active-nav" : "")" @onclick='() => NavigateToTab("blogs-setup")'>Blogs Setup</span>
    </nav>
    </div> *@
    <div class="nav-dash">
        <nav class="admin-nav-bar-vertical d-flex flex-column">
            <span class="nav-link-item @(selectedTab == 1 ? "active-nav" : "")" @onclick='() => NavigateToTab(1)'>Dashboard Home</span>
            <span class="nav-link-item @(selectedTab == 2 ? "active-nav" : "")" @onclick='() => NavigateToTab(2)'>Family Setup</span>
            <span class="nav-link-item @(selectedTab == 3 ? "active-nav" : "")" @onclick='() => NavigateToTab(3)'>Family List</span>
            <span class="nav-link-item @(selectedTab == 4 ? "active-nav" : "")" @onclick='() => NavigateToTab(4)'>Galleries Setup</span>
            <span class="nav-link-item @(selectedTab == 5 ? "active-nav" : "")" @onclick='() => NavigateToTab(5)'>Blogs Setup</span>
        </nav>
    </div>
    <div class="content-area flex-grow-1 p-4">
        @if (selectedTab == 1)
        {
            @if (dashboardview?.Generations != null)
            {
                <div class="container-fluid px-4">
                    <div class="row gx-4 gy-4">
                        <!-- Left Side: Count Cards -->
                        <div class="col-12 col-md-6 d-flex flex-column gap-3">
                            @{
                                var leftSideGenerations = dashboardview.Generations
                                .Where(g => !g.Key.Contains("Generation") && !g.Key.Contains("Marital") && !g.Key.Contains("'s"))
                                .ToList();

                                int groupCount = (int)Math.Ceiling((double)leftSideGenerations.Count / 3);
                            }

                            @for (int i = 0; i < groupCount; i++)
                            {
                                <div class="row g-3">
                                    @foreach (var generation in leftSideGenerations.Skip(i * 3).Take(3))
                                    {
                                        <div class="col-12 col-sm-6 col-md-4 d-flex">
                                            <div class="w-100 d-flex flex-column justify-content-center text-center p-4" style="background-color: @(GetCardColor(generation.Key)); color: #3E000B; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); height: 200px; cursor: pointer;">
                                                <div style="font-size: 14px; font-weight: 600; margin-bottom: 8px;">
                                                    @if (generation.Key == "TotalFamilyMember")
                                                    {
                                                        <span @onclick="()=>Navigate()">Total Family Members</span>
                                                    }
                                                    else if (generation.Key == "AverageLifespan")
                                                    {
                                                        <span>Average Lifespan</span>
                                                    }
                                                    else if (generation.Key == "LongestLivingIndividual")
                                                    {
                                                        <span>Longest Living Individual</span>
                                                    }
                                                    else
                                                    {
                                                        @generation.Key
                                                    }
                                                </div>
                                                <div style="font-size: @(generation.Value is string ? "16px" : "32px"); font-weight: 700; color: #008080;">
                                                    @if (generation.Value is string)
                                                    {
                                                        @generation.Value
                                                    }
                                                    else if (generation.Value is int)
                                                    {
                                                        @((int)generation.Value)
                                                    }
                                                    else if (generation.Key == "LongestLivingIndividual")
                                                    {
                                                        <span style="font-size: 13px; color: #555;">@generation.Value</span>
                                                    }
                                                    else
                                                    {
                                                        @generation.Value.ToString()
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Right Side: Charts -->
                        <div class="col-12 col-md-6">
                            <div class="row gx-3 gy-4">
                                <!-- Chart 1: Generation Chart -->
                                <div class="col-12 col-sm-6">
                                    @if (dashboardview?.Generations != null)
                                    {
                                        var generationData = dashboardview.Generations
                                        .Where(g => g.Key.Contains("Generation"))
                                        .ToDictionary(g => g.Key, g => g.Value);

                                        if (generationData.Any())
                                        {
                                            <div class="w-100" style="aspect-ratio: 1; background: white; padding: 24px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                                                <canvas id="generationChart" style="width: 100%; height: 100%;"></canvas>
                                            </div>
                                        }
                                    }
                                </div>

                                <!-- Chart 2: Marital Chart -->
                                <div class="col-12 col-sm-6">
                                    @if (dashboardview?.Generations != null)
                                    {
                                        var labelMap = new Dictionary<string, string>
                            {
                            { "MaritalSingle", "Single" },
                            { "MaritalMarried", "Married" },
                            { "MaritalDivorced", "Divorced" },
                            { "MaritalWidowed", "Widowed" },
                            { "MaritalIsolated", "Isolated" }
                            };

                                        var maritalData = dashboardview.Generations
                                        .Where(g => g.Key.Contains("Marital"))
                                        .ToDictionary(
                                        g => labelMap.ContainsKey(g.Key) ? labelMap[g.Key] : g.Key,
                                        g => g.Value
                                        );

                                        if (maritalData.Any())
                                        {
                                            <div class="w-100" style="aspect-ratio: 1; background: white; padding: 24px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                                                <canvas id="maritalChart" style="width: 100%; height: 100%;"></canvas>
                                            </div>
                                        }
                                    }
                                </div>

                                <!-- Chart 3: Age Group Chart -->
                                <div class="col-12">
                                    @if (dashboardview?.Generations != null)
                                    {
                                        var generationData = dashboardview.Generations
                                        .Where(g => g.Key.Contains("'s"))
                                        .ToDictionary(g => g.Key, g => g.Value);

                                        if (generationData.Any())
                                        {
                                            <div class="w-100" style="aspect-ratio: 2 / 1; background: white; padding: 24px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                                                <canvas id="AgeGroupChart" style="width: 100%; height: 100%;"></canvas>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>


            }
        }
        else if (selectedTab == 2)
        {
            <FamilyTreeMemberSetupPage />
        }
        else if (selectedTab == 3)
        {
            <LIstofFamilyTree tabId="@tabId" />
        }
        else if (selectedTab == 4)
        {
            <GallerySetupPage />
        }
        else if (selectedTab == 5)
        {
            <BlogsSetupPage />
        }
    </div>
</div>
<style>
    .table-striped tbody tr:nth-of-type(odd) {
        background-color: #f9f9f9;
    }

    .nav-dash {
        width: 250px; /* fixed width */
        min-width: 250px; /* prevent shrinking */
        max-width: 250px; /* prevent expanding */
        height: 80vh;
        background-color: #f8f9fa;
        border-right: 1px solid #ccc;
        box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
        padding: 20px 10px;
        flex-shrink: 0; /* stops the nav from shrinking on small screens */
    }



    .admin-nav-bar-vertical {
        gap: 10px;
    }

    .nav-link-item {
        cursor: pointer;
        font-weight: 500;
        color: #333;
        padding: 10px 16px;
        border-radius: 6px;
        transition: all 0.2s ease-in-out;
    }

        .nav-link-item:hover {
            background-color: #e9ecef;
            color: #007bff;
        }

    .active-nav {
        background-color: #007bff;
        color: white;
    }

    .content-area {
        padding: 20px;
        overflow-y: auto;
    }

    .scroll-content {
        padding: 15px;
    }

    .NavItem {
        margin-right: 20px;
        padding: 6px 12px;
        cursor: pointer;
    }

    .activeNavItem {
        background-color: #007bff;
        color: white;
        border-radius: 5px;
    }

    .table {
        width: 100%;
        margin-top: 20px;
    }

        .table th, .table td {
            text-align: left;
            padding: 10px;
        }

        .table th {
            background-color: #007bff; /* Blue color for the table heading */
            color: white; /* White text color */
        }

        .table img {
            border-radius: 50%;
        }
</style>
