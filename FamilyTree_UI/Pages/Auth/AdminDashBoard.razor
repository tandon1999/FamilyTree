@using FamilyTree_UI.Pages.Blogs
@using FamilyTree_UI.Pages.FamilySetups
@using FamilyTree_UI.Pages.Galleries
@using FamilyTree_UI.Shared.Services

@page "/admin"
@page "/admin/{tabId:int}"

<div class="d-flex">
    <div class="admin-shell container-fluid py-3 py-md-4">
        <div class="row g-3 g-md-4">
            <aside class="col-12 col-lg-3 col-xl-2">
                <div class="nav-dash">
                    <div class="admin-brand mb-3">
                        <h5 class="mb-1">Admin Panel</h5>
                        <small>FamilyTree Management</small>
                    </div>

                    <nav class="admin-nav-bar-vertical d-flex flex-column">
                        <button class="nav-link-item @(selectedTab == 1 ? "active-nav" : "")" @onclick='() => NavigateToTab(1)'>Dashboard Home</button>
                        <button class="nav-link-item @(selectedTab == 2 ? "active-nav" : "")" @onclick='() => NavigateToTab(2)'>Family Setup</button>
                        <button class="nav-link-item @(selectedTab == 3 ? "active-nav" : "")" @onclick='() => NavigateToTab(3)'>Family List</button>
                        <button class="nav-link-item @(selectedTab == 4 ? "active-nav" : "")" @onclick='() => NavigateToTab(4)'>Galleries Setup</button>
                        <button class="nav-link-item @(selectedTab == 5 ? "active-nav" : "")" @onclick='() => NavigateToTab(5)'>Blogs Setup</button>
                    </nav>
                </div>
            </aside>

            <main class="col-12 col-lg-9 col-xl-10">
                <div class="content-area">
                    <div class="dashboard-header mb-4">
                        <h3 class="mb-1">@(selectedTab == 1 ? "Dashboard Overview" : selectedTab == 2 ? "Family Setup" : selectedTab == 3 ? "Family List" : selectedTab == 4 ? "Gallery Setup" : "Blogs Setup")</h3>
                        <p class="mb-0">Manage records, monitor insights, and update family content from one place.</p>
                    </div>

                    @if (selectedTab == 1)
                    {
                        @if (dashboardview?.Generations != null)
                        {
                            <div class="row gx-3 gy-3 gx-md-4 gy-md-4">
                                <div class="col-12 col-xxl-5 d-flex flex-column gap-3">
                                    @{
                                        var leftSideGenerations = dashboardview.Generations
                                        .Where(g => !g.Key.Contains("Generation") && !g.Key.Contains("Marital") && !g.Key.Contains("'s"))
                                        .ToList();

                                        int groupCount = (int)Math.Ceiling((double)leftSideGenerations.Count / 2);
                                    }

                                    @for (int i = 0; i < groupCount; i++)
                                    {
                                        <div class="row g-3">
                                            @foreach (var generation in leftSideGenerations.Skip(i * 2).Take(2))
                                            {
                                                <div class="col-12 col-md-6 d-flex">
                                                    <div class="stat-card w-100" style="background-color: @(GetCardColor(generation.Key));">
                                                        <div class="stat-label">
                                                            @if (generation.Key == "TotalFamilyMember")
                                                            {
                                                                <span class="stat-link" @onclick="()=>Navigate()">Total Family Members</span>
                                                            }
                                                            else if (generation.Key == "AverageLifespan")
                                                            {
                                                                <span>Average Lifespan</span>
                                                            }
                                                            else if (generation.Key == "LongestLivingIndividual")
                                                            {
                                                                <span>Longest Living Individual</span>
                                                            }
                                                            else
                                                            {
                                                                @generation.Key
                                                            }
                                                        </div>
                                                        <div class="stat-value @(generation.Value is string ? "value-sm" : "")">
                                                            @if (generation.Value is string)
                                                            {
                                                                @generation.Value
                                                            }
                                                            else if (generation.Value is int)
                                                            {
                                                                @((int)generation.Value)
                                                            }
                                                            else
                                                            {
                                                                @generation.Value.ToString()
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="col-12 col-xxl-7">
                                    <div class="row g-3 g-md-4">
                                        <div class="col-12 col-md-6">
                                            @if (dashboardview?.Generations != null)
                                            {
                                                var generationData = dashboardview.Generations
                                                .Where(g => g.Key.Contains("Generation"))
                                                .ToDictionary(g => g.Key, g => g.Value);

                                                if (generationData.Any())
                                                {
                                                    <div class="chart-card chart-square">
                                                        <canvas id="generationChart"></canvas>
                                                    </div>
                                                }
                                            }
                                        </div>

                                        <div class="col-12 col-md-6">
                                            @if (dashboardview?.Generations != null)
                                            {
                                                var labelMap = new Dictionary<string, string>
                                                {
                                                    { "MaritalSingle", "Single" },
                                                    { "MaritalMarried", "Married" },
                                                    { "MaritalDivorced", "Divorced" },
                                                    { "MaritalWidowed", "Widowed" },
                                                    { "MaritalIsolated", "Isolated" }
                                                };

                                                var maritalData = dashboardview.Generations
                                                .Where(g => g.Key.Contains("Marital"))
                                                .ToDictionary(
                                                g => labelMap.ContainsKey(g.Key) ? labelMap[g.Key] : g.Key,
                                                g => g.Value
                                                );

                                                if (maritalData.Any())
                                                {
                                                    <div class="chart-card chart-square">
                                                        <canvas id="maritalChart"></canvas>
                                                    </div>
                                                }
                                            }
                                        </div>

                                        <div class="col-12">
                                            @if (dashboardview?.Generations != null)
                                            {
                                                var ageGroupData = dashboardview.Generations
                                                .Where(g => g.Key.Contains("'s"))
                                                .ToDictionary(g => g.Key, g => g.Value);

                                                if (ageGroupData.Any())
                                                {
                                                    <div class="chart-card chart-wide">
                                                        <canvas id="AgeGroupChart"></canvas>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else if (selectedTab == 2)
                    {
                        <FamilyTreeMemberSetupPage />
                    }
                    else if (selectedTab == 3)
                    {
                        <LIstofFamilyTree tabId="@tabId" />
                    }
                    else if (selectedTab == 4)
                    {
                        <GallerySetupPage />
                    }
                    else if (selectedTab == 5)
                    {
                        <BlogsSetupPage />
                    }
                </div>
            </main>
        </div>
    </div>
</div>
<style>
    .admin-shell {
        width: 100%;
    }

    .nav-dash {
        background: #ffffff;
        border: 1px solid #e2e9f7;
        border-radius: 1rem;
        box-shadow: 0 10px 24px rgba(21, 48, 93, 0.08);
        padding: 1rem;
        position: sticky;
        top: 1rem;
    }

    .admin-nav-bar-vertical {
        gap: .55rem;
    }

    .admin-brand h5 {
        color: #1f2f4f;
        font-weight: 700;
    }

    .admin-brand small {
        color: #6a7e9f;
    }

    .nav-link-item {
        cursor: pointer;
        font-weight: 600;
        color: #31476f;
        padding: .7rem .85rem;
        border-radius: .65rem;
        border: 1px solid #e8edf8;
        background: #f9fbff;
        text-align: left;
        transition: all 0.2s ease-in-out;
    }

        .nav-link-item:hover {
            background-color: #eef4ff;
            color: #2e5faf;
            border-color: #d6e3fb;
        }

    .active-nav {
        background: linear-gradient(135deg, #2f59ae 0%, #3d6dcf 100%);
        color: white;
        border-color: transparent;
    }

    .content-area {
        background: #fff;
        border: 1px solid #e2e9f7;
        border-radius: 1rem;
        box-shadow: 0 10px 24px rgba(21, 48, 93, 0.07);
        padding: 1rem;
        overflow-y: auto;
    }

    .dashboard-header {
        border: 1px solid #e2e9f7;
        border-radius: .85rem;
        background: linear-gradient(135deg, #eef4ff 0%, #f8faff 100%);
        padding: 1rem;
    }

    .dashboard-header h3 {
        color: #1e2d4a;
        font-weight: 700;
    }

    .dashboard-header p {
        color: #5c6f91;
    }

    .stat-card {
        border-radius: .85rem;
        border: 1px solid rgba(0, 0, 0, 0.05);
        box-shadow: 0 8px 20px rgba(17, 40, 81, 0.1);
        padding: 1rem;
        min-height: 140px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .stat-label {
        font-size: .9rem;
        font-weight: 700;
        color: #2c3b58;
        margin-bottom: .45rem;
    }

    .stat-link {
        cursor: pointer;
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #0b6b6b;
        line-height: 1.2;
    }

    .stat-value.value-sm {
        font-size: 1.05rem;
    }

    .chart-card {
        background: #fff;
        border: 1px solid #e3eaf8;
        border-radius: .85rem;
        box-shadow: 0 8px 20px rgba(18, 43, 89, 0.08);
        padding: .85rem;
    }

    .chart-square {
        aspect-ratio: 1;
    }

    .chart-wide {
        aspect-ratio: 2 / 1;
    }

    .chart-card canvas {
        width: 100% !important;
        height: 100% !important;
    }

    @@media (max-width: 991.98px) {
        .nav-dash {
            position: static;
        }
    }
</style>
