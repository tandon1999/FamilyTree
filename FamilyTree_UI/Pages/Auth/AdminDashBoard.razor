@using FamilyTree_UI.Pages.Blogs
@using FamilyTree_UI.Pages.FamilySetups
@using FamilyTree_UI.Pages.Galleries
@using FamilyTree_UI.Shared.Services

@page "/admin"
@page "/admin/{tabId:int}"

<div class="d-flex">
@*     <div class="nav-dash">
        <nav class="admin-nav-bar-vertical d-flex flex-column">
            <span class="nav-link-item @(selectedTab == "dashboardhome" ? "active-nav" : "")" @onclick='() => NavigateToTab("dashboardhome")'>Dashboard Home</span>
            <span class="nav-link-item @(selectedTab == "Family-setup" ? "active-nav" : "")" @onclick='() => NavigateToTab("Family-setup")'>Family Setup</span>
            <span class="nav-link-item @(selectedTab == "Family-list" ? "active-nav" : "")" @onclick='() => NavigateToTab("Family-list")'>Family List</span>
            <span class="nav-link-item @(selectedTab == "gallery-setup" ? "active-nav" : "")" @onclick='() => NavigateToTab("gallery-setup")'>Galleries Setup</span>
            <span class="nav-link-item @(selectedTab == "blogs-setup" ? "active-nav" : "")" @onclick='() => NavigateToTab("blogs-setup")'>Blogs Setup</span>
        </nav>
    </div> *@
    <div class="nav-dash">
        <nav class="admin-nav-bar-vertical d-flex flex-column">
            <span class="nav-link-item @(selectedTab == 1 ? "active-nav" : "")" @onclick='() => NavigateToTab(1)'>Dashboard Home</span>
            <span class="nav-link-item @(selectedTab == 2 ? "active-nav" : "")" @onclick='() => NavigateToTab(2)'>Family Setup</span>
            <span class="nav-link-item @(selectedTab == 3 ? "active-nav" : "")" @onclick='() => NavigateToTab(3)'>Family List</span>
            <span class="nav-link-item @(selectedTab == 4 ? "active-nav" : "")" @onclick='() => NavigateToTab(4)'>Galleries Setup</span>
            <span class="nav-link-item @(selectedTab == 5 ? "active-nav" : "")" @onclick='() => NavigateToTab(5)'>Blogs Setup</span>
        </nav>
    </div>
    <div class="content-area flex-grow-1 p-4">
        @if (selectedTab == 1)
        {
            @if (dashboardview?.Generations != null)
            {
                <div style="display: flex; justify-content: center; gap: 24px; padding: 0 40px; min-width: 0;">
                    <!-- Left Side: Count Cards -->
                    <div style="flex: 1; display: flex; flex-wrap: wrap; gap: 16px; justify-content: center;">
                        @foreach (var generation in dashboardview.Generations.Where(g => !g.Key.Contains("Generation") && !g.Key.Contains("Marital")))
                        {
                            <div class="col-md-3" style="cursor:pointer">
                                <div class="card shadow-lg mb-4" style="min-height: 100px; background-color: @(GetCardColor(generation.Key)); border-radius: 10px; margin-left: 5px; margin-right: 5px;">
                                    <div class="card-body">
                                        <h5 class="card-title text-primary font-weight-bold">
                                            @if (generation.Key == "TotalFamilyMember")
                                            {
                                                <span @onclick="()=>Navigate()">Total Family Member</span>
                                            }
                                            else if (generation.Key == "AverageLifespan")
                                            {
                                                <span>Average Lifespan</span>
                                            }
                                            else if (generation.Key == "LongestLivingIndividual")
                                            {
                                                <span>Longest Living Individual</span>
                                            }
                                            else
                                            {
                                                @generation.Key
                                            }
                                        </h5>
                                        <p class="card-text" style="color: #008080; font-size: @(generation.Value is string ? "small" : "xx-large");">
                                            @if (generation.Value is string)
                                            {
                                                @generation.Value
                                            }
                                            else if (generation.Value is int)
                                            {
                                                @((int)generation.Value)
                                            }
                                            else if (generation.Key == "LongestLivingIndividual")
                                            {
                                                <div>
                                                    <span style="font-size: 20px; color: #555;">@generation.Value</span>
                                                </div>
                                            }

                                            else
                                            {
                                                @generation.Value.ToString()
                                            }
                                        </p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    @if (dashboardview?.Generations != null)
                    {
                        var generationData = dashboardview.Generations
                        .Where(g => g.Key.Contains("Generation"))
                        .ToDictionary(g => g.Key, g => g.Value);

                        if (generationData.Any())
                        {
                            <div style="width: 400px; height: 400px; background: white; padding: 24px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                                <canvas id="generationChart" width="200" height="200"></canvas>
                            </div>
                        }
                    }
                    @if (dashboardview?.Generations != null)
                    {
                        var labelMap = new Dictionary<string, string>
            {
            { "MaritalSingle", "Single" },
            { "MaritalMarried", "Married" },
            { "MaritalDivorced", "Divorced" },
            { "MaritalWidowed", "Widowed" },
            { "MaritalIsolated", "Isolated" }
            };

                        var maritalData = dashboardview.Generations
                        .Where(g => g.Key.Contains("Marital"))
                        .ToDictionary(
                        g => labelMap.ContainsKey(g.Key) ? labelMap[g.Key] : g.Key,
                        g => g.Value
                        );
                        if (maritalData.Any())
                        {
                            <div style="width: 400px; height: 400px; background: white; padding: 24px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                                <canvas id="maritalChart" width="200" height="200"></canvas>
                            </div>
                        }
                    }
                </div>
            }
        }
        else if (selectedTab == 2)
        {
            <FamilyTreeMemberSetupPage />
        }
        else if (selectedTab == 3)
        {
            <LIstofFamilyTree />
        }
        else if (selectedTab == 4)
        {
            <GallerySetupPage />
        }
        else if (selectedTab == 5)
        {
            <BlogsSetupPage />
        }
    </div>
</div>
<style>
    .table-striped tbody tr:nth-of-type(odd) {
        background-color: #f9f9f9;
    }

    .nav-dash {
        width: 250px;
        height: 100vh;
        background-color: #f8f9fa;
        border-right: 1px solid #ccc;
        box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
        padding: 20px 10px;
    }


    .admin-nav-bar-vertical {
        gap: 10px;
    }

    .nav-link-item {
        cursor: pointer;
        font-weight: 500;
        color: #333;
        padding: 10px 16px;
        border-radius: 6px;
        transition: all 0.2s ease-in-out;
    }

        .nav-link-item:hover {
            background-color: #e9ecef;
            color: #007bff;
        }

    .active-nav {
        background-color: #007bff;
        color: white;
    }

    .content-area {
        padding: 20px;
        overflow-y: auto;
    }

    .scroll-content {
        padding: 15px;
    }

    .NavItem {
        margin-right: 20px;
        padding: 6px 12px;
        cursor: pointer;
    }

    .activeNavItem {
        background-color: #007bff;
        color: white;
        border-radius: 5px;
    }

    .table {
        width: 100%;
        margin-top: 20px;
    }

        .table th, .table td {
            text-align: left;
            padding: 10px;
        }

        .table th {
            background-color: #007bff; /* Blue color for the table heading */
            color: white; /* White text color */
        }

        .table img {
            border-radius: 50%;
        }
</style>
