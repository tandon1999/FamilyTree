@page "/Getgallery"
<PageTitle>Galleries</PageTitle>

@using FamilyTree_UI.Shared.Component
@inherits LayoutComponentBase

<link href="css/Getgallery.css" rel="stylesheet" />

<div class="gallery-page container py-4 py-md-5">
    <section class="gallery-hero mb-4 mb-md-5">
        <p class="gallery-kicker mb-2">Memory Collection</p>
        <h1 class="gallery-title mb-2">Present & Past Through Camera Lens</h1>
        <p class="gallery-subtitle mb-0">A visual archive of moments, people and milestones from the Tandan family story.</p>
    </section>

    @if (gallerySetupslist != null && gallerySetupslist.Count > 0)
    {
        <div class="gallery-grid">
            @foreach (var image in gallerySetupslist)
            {
                <article class="image-card @GetCategoryClass(image.CategoryName)">
                    <img src="@image.ImageSrc" alt="@image.PhotoName" class="gallery-image" @onload="(() => HandleImageLoadComplete())" @onerror="(() => HandleImageLoadComplete())" />
                    <div class="image-overlay">
                        <div class="overlay-pill">@GetCategoryLabel(image.CategoryName)</div>
                        <div class="overlay-content">
                            <small class="overlay-date">@ConvertNE.ConvertEToNWithSlash(@image.DateofPhoto)</small>
                            <h5 class="overlay-title">@image.PhotoName</h5>
                            <p class="overlay-description mb-0">@image.Description</p>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>

